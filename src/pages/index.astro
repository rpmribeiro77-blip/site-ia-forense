---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="IA Forense | Início">
  <section class="hero">
    <div class="hero-split">
      <div>
        <span class="tag">Versão MVP</span>
        <h1>Inteligência artificial aplicada à prática forense</h1>
        <p class="meta"><strong>IA Forense por <em>Rodrigo Pereira Martins Ribeiro</em></strong> · <a href="/sobre/#curriculo-autor">Currículo e contato</a></p>
        <p>
          Aplicação prática de IA no dia a dia jurídico, com foco em produtividade, qualidade crítica e uso
          no âmbito do Direito e do Processo Civil.
        </p>
        <p class="meta">Ferramentas de IA para escrita jurídica e agentes.</p>
        <a href="/ia-forense/" class="cta">Explorar IA Forense</a>
        <a href="/processo-civil/" class="cta alt">Ver Processo Civil</a>
      </div>
      <div
        class="hero-visual"
        aria-label="Ilustração jurídica e tecnológica"
        style="max-width: 260px; width: min(100%, 260px); margin-left: auto;"
      >
        <svg
          class="hero-illustration"
          width="260"
          height="179"
          viewBox="0 0 900 620"
          role="img"
          aria-label="Balança da justiça integrada com elementos tecnológicos"
          xmlns="http://www.w3.org/2000/svg"
          style="display:block; width:100%; height:auto;"
        >
          <defs>
            <linearGradient id="bg" x1="0" y1="0" x2="900" y2="620" gradientUnits="userSpaceOnUse">
              <stop stop-color="#F4F9FF"/>
              <stop offset="1" stop-color="#E8F1FC"/>
            </linearGradient>
            <linearGradient id="blue" x1="180" y1="115" x2="720" y2="520" gradientUnits="userSpaceOnUse">
              <stop stop-color="#1E87EF"/>
              <stop offset="1" stop-color="#0A4B9B"/>
            </linearGradient>
            <linearGradient id="gold" x1="270" y1="260" x2="625" y2="495" gradientUnits="userSpaceOnUse">
              <stop stop-color="#D5A451"/>
              <stop offset="1" stop-color="#B27B2A"/>
            </linearGradient>
          </defs>
          <rect width="900" height="620" rx="28" fill="url(#bg)"/>
          <g opacity="0.35" stroke="#9AB8DB" stroke-width="2">
            <path d="M70 115H240V285"/>
            <circle cx="70" cy="115" r="6" fill="#9AB8DB"/>
            <circle cx="240" cy="285" r="6" fill="#9AB8DB"/>
            <path d="M830 115H660V285"/>
            <circle cx="830" cy="115" r="6" fill="#9AB8DB"/>
            <circle cx="660" cy="285" r="6" fill="#9AB8DB"/>
          </g>
          <rect x="370" y="170" width="160" height="265" rx="18" fill="url(#blue)"/>
          <rect x="355" y="145" width="190" height="38" rx="10" fill="#1A6FC5"/>
          <rect x="325" y="430" width="250" height="28" rx="10" fill="#D2E2F5"/>
          <rect x="285" y="460" width="330" height="24" rx="8" fill="#C1D4EC"/>
          <rect x="235" y="490" width="430" height="20" rx="7" fill="#AFC5E2"/>
          <rect x="210" y="250" width="140" height="16" rx="8" fill="#1A6FC5"/>
          <rect x="550" y="250" width="140" height="16" rx="8" fill="#1A6FC5"/>
          <path d="M280 266L222 350H338L280 266Z" fill="url(#gold)"/>
          <path d="M620 266L562 350H678L620 266Z" fill="url(#gold)"/>
        </svg>
      </div>
    </div>
  </section>

  <section>
    <h2>Seções principais</h2>
    <div class="grid">
      <article class="card">
        <h3>IA Forense (Em construção)</h3>
        <p>Guias e tutoriais prontos e noções de códigos para rotina forense. Modelos generativos de linguagem e agentes.</p>
        <a href="/ia-forense/">Entrar</a>
      </article>
      <article class="card">
        <h3>Processo Civil (Em construção)</h3>
        <p>Conteúdo exclusivo com enfoque técnico e utilidade prática envolvendo recursos tecnológicos.</p>
        <a href="/processo-civil/">Entrar</a>
      </article>
      <article class="card">
        <h3>Reflexões (Em construção)</h3>
        <p>Análises autorais sobre tendências, riscos e limites da IA no Direito.</p>
        <a href="/opiniao/">Entrar</a>
      </article>
      <article class="card">
        <h3>Biblioteca (Em construção)</h3>
        <p>Seleção de vídeos, artigos, ferramentas e links de referência.</p>
        <a href="/biblioteca/">Entrar</a>
      </article>
    </div>
  </section>
</BaseLayout>
