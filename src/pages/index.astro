---
import BaseLayout from "../layouts/BaseLayout.astro";
const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout title="IA Forense | Início">
  <section class="hero">
    <div class="hero-split">
      <div>
        <span class="tag">Versão MVP</span>
        <h1>Inteligência artificial aplicada à prática forense</h1>
        <p class="meta"><strong>IA Forense por Rodrigo Pereira Martins Ribeiro</strong> · <a href="/sobre/#curriculo-autor">Currículo do autor</a></p>
        <p>
          Este site nasce para ensinar aplicação prática de IA no dia a dia jurídico, com foco em produtividade,
          qualidade técnica e responsabilidade no uso no âmbito do Direito e do Processo Civil.
        </p>
        <a href="/ia-forense/" class="cta">Explorar IA Forense</a>
        <a href="/processo-civil/" class="cta alt">Ver Processo Civil</a>
      </div>
      <div class="hero-visual">
        <img src={`${baseUrl}legal-tech-hero.svg`} alt="Ilustração de balança da justiça integrada a circuitos tecnológicos" />
      </div>
    </div>
  </section>

  <section>
    <h2>Seções principais</h2>
    <div class="grid">
      <article class="card">
        <h3>IA Forense</h3>
        <p>Guias, tutoriais, prompts e noções de código para rotina forense.</p>
        <a href="/ia-forense/">Entrar</a>
      </article>
      <article class="card">
        <h3>Processo Civil (Em construção)</h3>
        <p>Conteúdo exclusivo com enfoque técnico e utilidade prática.</p>
        <a href="/processo-civil/">Entrar</a>
      </article>
      <article class="card">
        <h3>Opinião (Em construção)</h3>
        <p>Análises autorais sobre tendências, riscos e limites da IA no Direito.</p>
        <a href="/opiniao/">Entrar</a>
      </article>
      <article class="card">
        <h3>Biblioteca (Em construção)</h3>
        <p>Seleção prática de vídeos, artigos, ferramentas e links de referência.</p>
        <a href="/biblioteca/">Entrar</a>
      </article>
    </div>
  </section>
</BaseLayout>
