---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Biblioteca | IA Forense">
  <h1>Biblioteca</h1>
  <p class="meta">Organização de materiais para estudo e aplicação prática de IA no campo jurídico.</p>

  <div class="grid">
    <article class="card">
      <span class="tag">Vídeos</span>
      <h3>Vídeos</h3>
      <p>Conteúdos audiovisuais com demonstrações, comentários e aplicações práticas.</p>
    </article>
    <article class="card">
      <span class="tag">Artigos</span>
      <h3>Artigos</h3>
      <p>Textos técnicos e analíticos para aprofundamento de temas jurídicos e tecnológicos.</p>
    </article>
    <article class="card">
      <span class="tag">Ferramentas</span>
      <h3>Ferramentas</h3>
      <p>Recursos digitais para pesquisa, redação, revisão e organização da prática forense.</p>
    </article>
    <article class="card">
      <span class="tag">Documentos</span>
      <h3>Documentos</h3>
      <p>Materiais de apoio, modelos e arquivos para consulta estruturada.</p>
    </article>
    <article class="card">
      <span class="tag">Referências</span>
      <h3>Referências</h3>
      <p>Fontes de estudo selecionadas para aprofundamento teórico e prático.</p>
    </article>
    <article class="card">
      <span class="tag">Normas</span>
      <h3>Normas</h3>
      <p>Conjunto de normas com descrição e acesso direto aos arquivos em PDF.</p>
      <p><a href="https://rpmribeiro77-blip.github.io/ia-forense/biblioteca/normas/">Abrir seção de normas</a></p>
    </article>
  </div>
</BaseLayout>
