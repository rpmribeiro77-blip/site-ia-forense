---
import fs from "node:fs";
import path from "node:path";
import BaseLayout from "../../layouts/BaseLayout.astro";

const raw = fs.readFileSync(
  path.join(process.cwd(), "public", "vocabulario-textos", "bloco-2.txt"),
  "utf-8"
);
const lines = raw.split(/\r?\n/);
const body = (lines.length > 2 ? lines.slice(2) : lines).join("\n");
---

<BaseLayout title="Vocabulário Tecnológico — Bloco 2">
  <span class="tag">Bloco 2</span>
  <h1>Vocabulário Tecnológico — Bloco 2</h1>
  <pre class="vocab-text">{body}</pre>
</BaseLayout>

<style>
  .vocab-text {
    white-space: pre-wrap;
    line-height: 1.58;
    font-family: "IBM Plex Serif", Georgia, serif;
    background: #f7fbff;
    border: 1px solid #bfd3e8;
    border-radius: 12px;
    padding: 1rem;
  }
</style>
