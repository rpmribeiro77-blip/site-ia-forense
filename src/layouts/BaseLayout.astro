---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title ?? Astro.props.frontmatter?.title ?? "IA Forense";
const pageDescription =
  description ??
  Astro.props.frontmatter?.description ??
  "IA Forense: inteligência artificial aplicada à prática forense e processo civil.";
const pageDepth = Astro.url.pathname
  .replace(/^\/|\/$/g, "")
  .split("/")
  .filter(Boolean).length;
const rootPath = pageDepth === 0 ? "./" : "../".repeat(pageDepth);
const linkTo = (path = "") => `${rootPath}${path.replace(/^\/+/, "")}`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Serif:wght@400;500;600&display=swap");
      :root {
        --bg: #dceee4;
        --surface: #f5fff8;
        --surface-soft: #e0f2e8;
        --text: #153323;
        --muted: #3e6650;
        --brand: #16864a;
        --brand-strong: #0d5f35;
        --accent: #8aa63a;
        --border: #b9d8c5;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        color: var(--text);
        font-family: "Space Grotesk", "Segoe UI", Tahoma, sans-serif;
        background:
          radial-gradient(circle at 8% 3%, #cce8d7 0, transparent 30%),
          radial-gradient(circle at 90% 92%, #c8e2d1 0, transparent 34%),
          linear-gradient(150deg, #e1f1e7, #d3eadc);
      }
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        opacity: 0.14;
        background-image:
          linear-gradient(to right, #78b78f2b 1px, transparent 1px),
          linear-gradient(to bottom, #78b78f2b 1px, transparent 1px);
        background-size: 30px 30px;
      }
      a { color: var(--brand-strong); }
      a:visited { color: var(--brand-strong); }
      p, li { font-family: "IBM Plex Serif", Georgia, serif; }
      .container { width: min(1120px, 92vw); margin: 0 auto; }
      header {
        position: sticky;
        top: 0;
        z-index: 20;
        backdrop-filter: blur(8px);
        background: #e5f4e9df;
        border-bottom: 1px solid var(--border);
      }
      .topbar {
        display: flex;
        gap: 1rem;
        justify-content: space-between;
        align-items: center;
        padding: 0.9rem 0;
      }
      .brand {
        text-decoration: none;
        color: var(--text);
        font-weight: 700;
        letter-spacing: 0.04em;
        font-size: 1.55rem;
        display: inline-flex;
        align-items: center;
      }
      .brand::before {
        content: "";
        width: 10px;
        height: 10px;
        border-radius: 2px;
        margin-right: 0.5rem;
        background: linear-gradient(45deg, var(--brand), var(--accent));
        box-shadow: 0 0 12px #16864a44;
      }
      nav { display: flex; flex-wrap: wrap; gap: 0.65rem; }
      nav a {
        text-decoration: none;
        font-size: 0.92rem;
        color: #245b38;
        padding: 0.35rem 0.62rem;
        border-radius: 999px;
        border: 1px solid transparent;
      }
      nav a:hover {
        border-color: #a8d6b9;
        background: #e8f8ed;
      }
      main { padding: 1.5rem 0 2.2rem; }
      :global(.hero) {
        border: 1px solid var(--border);
        background: linear-gradient(145deg, #f5fff8, #dff2e7 58%, #edf8f1);
        border-radius: 18px;
        padding: 1.55rem;
        box-shadow: 0 14px 30px #5d8f6e19;
      }
      :global(.hero-split) {
        display: grid;
        gap: 1.2rem;
        grid-template-columns: 1.45fr 280px;
        align-items: center;
      }
      :global(.hero-visual img),
      :global(.hero-visual svg) {
        width: 100%;
        max-width: 430px;
        max-height: 290px;
        height: auto;
        display: block;
        border: 1px solid #add6bb;
        border-radius: 12px;
        background: #f4fff7;
        margin: 0 auto;
      }
      :global(.hero-visual .hero-illustration) {
        width: 360px;
        height: auto;
        max-width: 100%;
      }
      :global(.grid) {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      }
      :global(.card) {
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1rem;
        background: linear-gradient(180deg, #f8fffa, #e6f4eb);
        box-shadow: 0 8px 16px #6e9b7d14;
      }
      :global(.card h3) { margin-bottom: 0.4rem; }
      :global(.tag) {
        display: inline-block;
        background: #e2f7e9;
        color: #0d5f35;
        border: 1px solid #b6dfc3;
        border-radius: 999px;
        font-size: 0.78rem;
        padding: 0.2rem 0.62rem;
        margin-right: 0.4rem;
      }
      :global(.meta) { color: var(--muted); font-size: 0.92rem; }
      footer {
        border-top: 1px solid var(--border);
        color: var(--muted);
        padding: 1rem 0 2rem;
        font-size: 0.9rem;
      }
      h1, h2, h3 { margin-top: 0.2rem; line-height: 1.2; }
      :global(.cta) {
        display: inline-block;
        margin-top: 0.6rem;
        background: linear-gradient(120deg, #16864a, #22a862);
        color: #ffffff;
        font-weight: 700;
        text-decoration: none;
        padding: 0.55rem 0.9rem;
        border-radius: 10px;
      }
      :global(.cta.alt) {
        background: linear-gradient(120deg, #718f2d, #9bb545);
        color: #ffffff;
      }
      @media (max-width: 900px) {
        :global(.hero-split) { grid-template-columns: 1fr; }
      }
      @media (max-width: 780px) {
        .topbar { align-items: flex-start; flex-direction: column; }
        nav { gap: 0.45rem; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container topbar">
        <a href={linkTo()} class="brand">IA Forense</a>
        <nav>
          <a href={linkTo("ia-forense/")}>IA Forense</a>
          <a href={linkTo("processo-civil/")}>Processo Civil</a>
          <a href={linkTo("opiniao/")}>Reflexões</a>
          <a href={linkTo("biblioteca/")}>Biblioteca</a>
          <a href={linkTo("sobre/#curriculo-autor")}>Currículo e contato</a>
          <a href={linkTo("sobre/")}>Sobre</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer>
      <div class="container">
        <strong>IA Forense</strong> · Direito, tecnologia e método para prática forense contemporânea.
      </div>
    </footer>
  </body>
</html>

