---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "IA Forense: inteligência artificial aplicada à prática forense e processo civil." } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      :root {
        --bg: #f5f0e8;
        --surface: #fffaf1;
        --text: #1f2a37;
        --muted: #5b6573;
        --brand: #0b6e4f;
        --accent: #b3541e;
        --border: #d9d1c6;
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        font-family: "Source Serif 4", Georgia, "Times New Roman", serif;
        color: var(--text);
        background:
          radial-gradient(circle at 15% 10%, #f1e5d1 0, transparent 40%),
          radial-gradient(circle at 85% 90%, #d8e8df 0, transparent 35%),
          var(--bg);
      }
      a {
        color: var(--brand);
      }
      .container {
        width: min(1080px, 92vw);
        margin: 0 auto;
      }
      header {
        position: sticky;
        top: 0;
        backdrop-filter: blur(6px);
        background: #fffaf1cc;
        border-bottom: 1px solid var(--border);
      }
      .topbar {
        display: flex;
        gap: 1rem;
        justify-content: space-between;
        align-items: center;
        padding: 0.8rem 0;
      }
      .brand {
        text-decoration: none;
        color: var(--text);
        font-weight: 700;
        letter-spacing: 0.02em;
      }
      nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
      }
      nav a {
        text-decoration: none;
        font-size: 0.95rem;
        padding: 0.35rem 0.6rem;
        border-radius: 999px;
      }
      nav a:hover {
        background: #eaf0ed;
      }
      main {
        padding: 1.2rem 0 2rem;
      }
      .hero {
        border: 1px solid var(--border);
        background: linear-gradient(145deg, #fffaf1, #f1f7f4);
        border-radius: 16px;
        padding: 1.4rem;
      }
      .grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      }
      .card {
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1rem;
        background: var(--surface);
      }
      .tag {
        display: inline-block;
        background: #e7f2ed;
        color: var(--brand);
        border: 1px solid #cfe3da;
        border-radius: 999px;
        font-size: 0.8rem;
        padding: 0.2rem 0.6rem;
        margin-right: 0.4rem;
      }
      .meta {
        color: var(--muted);
        font-size: 0.92rem;
      }
      footer {
        border-top: 1px solid var(--border);
        color: var(--muted);
        padding: 1rem 0 2rem;
        font-size: 0.9rem;
      }
      h1, h2, h3 {
        margin-top: 0.2rem;
      }
      .cta {
        display: inline-block;
        margin-top: 0.6rem;
        background: var(--brand);
        color: #fff;
        text-decoration: none;
        padding: 0.55rem 0.8rem;
        border-radius: 10px;
      }
      .cta.alt {
        background: var(--accent);
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container topbar">
        <a href="/" class="brand">IA Forense</a>
        <nav>
          <a href="/ia-forense/">IA Forense</a>
          <a href="/processo-civil/">Processo Civil</a>
          <a href="/opiniao/">Opinião</a>
          <a href="/biblioteca/">Biblioteca</a>
          <a href="/sobre/">Sobre</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer>
      <div class="container">
        <strong>IA Forense</strong> · Projeto editorial sobre prática forense, IA e processo civil.
      </div>
    </footer>
  </body>
</html>
