---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "IA Forense: inteligência artificial aplicada à prática forense e processo civil." } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Serif:wght@400;500;600&display=swap");
      :root {
        --bg: #d9e4f1;
        --surface: #f5f9ff;
        --surface-soft: #e2ecf9;
        --text: #132238;
        --muted: #415770;
        --brand: #0d6fd8;
        --brand-strong: #0a4b9b;
        --accent: #c28a2d;
        --border: #c2d4e8;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        color: var(--text);
        font-family: "Space Grotesk", "Segoe UI", Tahoma, sans-serif;
        background:
          radial-gradient(circle at 8% 3%, #cfdff2 0, transparent 30%),
          radial-gradient(circle at 90% 92%, #cedcf0 0, transparent 34%),
          linear-gradient(150deg, #e0e9f5, #d5e1ef);
      }
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        opacity: 0.14;
        background-image:
          linear-gradient(to right, #7da4cf2b 1px, transparent 1px),
          linear-gradient(to bottom, #7da4cf2b 1px, transparent 1px);
        background-size: 30px 30px;
      }
      a { color: var(--brand-strong); }
      a:visited { color: var(--brand-strong); }
      p, li { font-family: "IBM Plex Serif", Georgia, serif; }
      .container { width: min(1120px, 92vw); margin: 0 auto; }
      header {
        position: sticky;
        top: 0;
        z-index: 20;
        backdrop-filter: blur(8px);
        background: #e6eef8df;
        border-bottom: 1px solid var(--border);
      }
      .topbar {
        display: flex;
        gap: 1rem;
        justify-content: space-between;
        align-items: center;
        padding: 0.9rem 0;
      }
      .brand {
        text-decoration: none;
        color: var(--text);
        font-weight: 700;
        letter-spacing: 0.04em;
        font-size: 1.55rem;
        display: inline-flex;
        align-items: center;
      }
      .brand::before {
        content: "";
        width: 10px;
        height: 10px;
        border-radius: 2px;
        margin-right: 0.5rem;
        background: linear-gradient(45deg, var(--brand), var(--accent));
        box-shadow: 0 0 12px #0d6fd844;
      }
      nav { display: flex; flex-wrap: wrap; gap: 0.65rem; }
      nav a {
        text-decoration: none;
        font-size: 0.92rem;
        color: #24496f;
        padding: 0.35rem 0.62rem;
        border-radius: 999px;
        border: 1px solid transparent;
      }
      nav a:hover {
        border-color: #aecded;
        background: #eaf3ff;
      }
      main { padding: 1.5rem 0 2.2rem; }
      .hero {
        border: 1px solid var(--border);
        background: linear-gradient(145deg, #f5f9ff, #e0ebf9 58%, #edf4fd);
        border-radius: 18px;
        padding: 1.55rem;
        box-shadow: 0 14px 30px #5d7ea619;
      }
      .hero-split {
        display: grid;
        gap: 1.2rem;
        grid-template-columns: 1.3fr 1fr;
        align-items: center;
      }
      .hero-visual img,
      .hero-visual svg {
        width: 100%;
        max-width: 430px;
        max-height: 290px;
        height: auto;
        display: block;
        border: 1px solid #b7cbe4;
        border-radius: 12px;
        background: #f4f9ff;
        margin: 0 auto;
      }
      .grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      }
      .card {
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1rem;
        background: linear-gradient(180deg, #f8fbff, #e7f0fb);
        box-shadow: 0 8px 16px #6e8eb314;
      }
      .card h3 { margin-bottom: 0.4rem; }
      .tag {
        display: inline-block;
        background: #e5f2ff;
        color: #0a4b9b;
        border: 1px solid #bed8f7;
        border-radius: 999px;
        font-size: 0.78rem;
        padding: 0.2rem 0.62rem;
        margin-right: 0.4rem;
      }
      .meta { color: var(--muted); font-size: 0.92rem; }
      footer {
        border-top: 1px solid var(--border);
        color: var(--muted);
        padding: 1rem 0 2rem;
        font-size: 0.9rem;
      }
      h1, h2, h3 { margin-top: 0.2rem; line-height: 1.2; }
      .cta {
        display: inline-block;
        margin-top: 0.6rem;
        background: linear-gradient(120deg, #0d6fd8, #1e87ef);
        color: #ffffff;
        font-weight: 700;
        text-decoration: none;
        padding: 0.55rem 0.9rem;
        border-radius: 10px;
      }
      .cta.alt {
        background: linear-gradient(120deg, #b07a24, #c79238);
        color: #ffffff;
      }
      @media (max-width: 900px) {
        .hero-split { grid-template-columns: 1fr; }
      }
      @media (max-width: 780px) {
        .topbar { align-items: flex-start; flex-direction: column; }
        nav { gap: 0.45rem; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container topbar">
        <a href="/" class="brand">IA Forense</a>
        <nav>
          <a href="/ia-forense/">IA Forense</a>
          <a href="/processo-civil/">Processo Civil</a>
          <a href="/opiniao/">Opinião</a>
          <a href="/biblioteca/">Biblioteca</a>
          <a href="/sobre/#curriculo-autor">Currículo e contato</a>
          <a href="/sobre/">Sobre</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer>
      <div class="container">
        <strong>IA Forense</strong> · Direito, tecnologia e método para prática forense contemporânea.
      </div>
    </footer>
  </body>
</html>

